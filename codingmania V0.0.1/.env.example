# ---- docker-compose overrides (optional) ----
# Copy to ".env" next to docker-compose.yml to customise. All have sane defaults.

# MySQL container credentials (a fresh DB is created inside Docker)
DB_ROOT_PASSWORD=rootpass
DB_NAME=codemaniav01_db

# Origin allowed to open socket.io connections (the frontend URL)
FRONTEND_URL=http://localhost:8080

# Build-time values baked into the frontend bundle.
# For local Docker these point at the host-exposed backend.
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=
VITE_IMAGEKIT_URL=
