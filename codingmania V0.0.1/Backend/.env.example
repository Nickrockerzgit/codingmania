# ---- CodingMania Backend — environment variables ----
# Copy to ".env" and fill in your own values.

# Server
PORT=5000
BASE_URL=http://localhost:5000
WEBSITE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Extra socket.io/CORS origins (comma-separated). Localhost origins are always allowed.
# e.g. ALLOWED_ORIGINS=https://app.codingmania.com,https://admin.codingmania.com
ALLOWED_ORIGINS=

# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/codemaniav01_db"

# Auth (JWT)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Email / OTP (SMTP via Nodemailer)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# AI
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ImageKit (media uploads)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Razorpay (event payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Upstash Redis (optional — distributed rate limiting for auth/OTP)
# Leave blank to use the in-memory limiter instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
